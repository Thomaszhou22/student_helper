# Copy this file to `.env` in the project root and fill in values.
# Dashboard: https://supabase.com → your project → Settings → API
# - Project URL → VITE_SUPABASE_URL (e.g. https://xxxx.supabase.co)
# - anon public key → VITE_SUPABASE_ANON_KEY (long JWT; no extra quotes)
# Restart the Vite dev server after changing .env (`npm run dev`).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
